# .env.example
HOST=0.0.0.0
PORT=5000
ALLOWED_ORIGINS=http://localhost:3000
BACKEND_URL=http://localhost:5000
DATABASE_PASSWORD = "1991"
DATABASE_HOST = "localhost"
# OAuth client ID(s) from Google Cloud Console → Credentials (same GCP project as the app).
# Primary: Web application client ID — must match frontend/local.properties GOOGLE_CLIENT_ID (server client id).
# If you still see "wrong audience", add the Android OAuth client ID too (comma-separated, no spaces):
# GOOGLE_CLIENT_ID=WEB_CLIENT_ID.apps.googleusercontent.com,ANDROID_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
JWT_SECRET=your_jwt_secret_here
# Same value on each ESP32 (microcontroller/src/config.py ESP32_INGEST_SECRET). Required for POST /api/events/ingest.
ESP32_INGEST_SECRET=generate-a-long-random-string
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json